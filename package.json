{
  "name": "ios-apps",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "ci": "npm run typecheck && npm run lint",
    "codemagic:version": "node scripts/set-codemagic-build-version.js",
    "codemagic:android-signing": "node scripts/configure-android-signing.js",
    "build:ios": "npx eas build --platform ios --profile production",
    "build:android": "npx eas build --platform android --profile production",
    "build:ios:preview": "npx eas build --platform ios --profile preview",
    "build:android:preview": "npx eas build --platform android --profile preview",
    "submit:ios": "npx eas submit --platform ios --profile production",
    "submit:android": "npx eas submit --platform android --profile production",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^6.5.16",
    "@react-navigation/native": "^6.1.10",
    "expo": "~54.0.0",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-keep-awake": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.5",
    "@react-native/js-polyfills": "0.81.5",
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "metro": "^0.83.1",
    "metro-config": "^0.83.1",
    "metro-resolver": "^0.83.1",
    "typescript": "~5.9.2"
  }
}
